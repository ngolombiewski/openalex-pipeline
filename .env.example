OPENALEX_API_KEY=
OPENALEX_FILTER=
OPENALEX_START_YEAR=
OPENALEX_END_YEAR=
OPENALEX_DATA_ROOT=
OPENALEX_GCS_BUCKET=
# GCP project ID — used by dbt (profiles.yml, sources.yml)
OPENALEX_GCP_PROJECT=
# In-repo dbt profile location (relative to repo root; run dbt from there)
DBT_PROFILES_DIR=dbt
# dbt log location. The log path is resolved relative to the CWD (not
# --project-dir), so without this dbt drops logs/ at the repo root when invoked
# from there. Supersedes the deprecated dbt_project.yml `log-path`.
DBT_LOG_PATH=dbt/logs
# DAGSTER_HOME is exported as an absolute path, initialized, and linked to the
# tracked root dagster.yaml by .envrc. Do not set it here.
